# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# AI Provider API Keys (set at least one)
# Get your keys from:
#   Anthropic: https://console.anthropic.com/
#   Google: https://aistudio.google.com/apikey
#   OpenAI: https://platform.openai.com/api-keys
#   xAI: https://console.x.ai/
ANTHROPIC_API_KEY=****
GOOGLE_GENERATIVE_AI_API_KEY=****
OPENAI_API_KEY=****
XAI_API_KEY=****

# PostgreSQL Connection
POSTGRES_URL=****

# Redis (optional, for resumable streams)
# REDIS_URL=****

# Vercel Blob (optional, for file uploads)
# BLOB_READ_WRITE_TOKEN=****

# Suppress outdated browserslist data warnings from Next.js bundled copy
BROWSERSLIST_IGNORE_OLD_DATA=true

# System user IDs for actor tracking (generated by database/migrations/add-system-users.sql)
CHAT_ASSISTANT_USER_ID=****
MCP_ASSISTANT_USER_ID=****

# ─── GitHub Copilot Pro+ Integration ──────────────────────────────────────────
# Personal Access Token (classic) with the `user` scope, or a fine-grained token
# granted access to your GitHub Copilot subscription.
# Used to:
#   1. Route AI model requests through the GitHub Copilot API (Pro+ models)
#      at https://api.githubcopilot.com — no separate Anthropic/OpenAI keys needed.
#   2. Authenticate the GitHub MCP server for codebase-aware tool calls.
# Create a token: https://github.com/settings/tokens
# List available models: GET https://api.githubcopilot.com/models (with this token)
GITHUB_TOKEN=****

# Set to "true" to enable Copilot Pro+ models in the model selector
NEXT_PUBLIC_USE_COPILOT_SDK=false

# Supabase — Cloud
NEXT_PUBLIC_SUPABASE_URL=****
NEXT_PUBLIC_SUPABASE_ANON_KEY=****
SUPABASE_SERVICE_ROLE_KEY=****

# Supabase — Local (uncomment to use local Supabase instead of Cloud)
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=****
# SUPABASE_SERVICE_ROLE_KEY=****

# SPLM database — Cloud (splm schema)
# Connection string from Dashboard > Settings > Database, with search_path appended
SPLM_POSTGRES_URL=****

# SPLM database — Supabase local PostgreSQL (uncomment to use local)
# SPLM_POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?options=-csearch_path%3Dsplm%2Cpublic
